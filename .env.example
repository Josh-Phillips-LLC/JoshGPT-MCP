# Copy to .env and set values.

# -----------------------------------------------------------------------------
# MCP tool-host runtime (existing service)
# -----------------------------------------------------------------------------
JOSHGPT_MCP_BIND_HOST=0.0.0.0
JOSHGPT_MCP_BIND_PORT=8787
JOSHGPT_MCP_TRANSPORT=streamable-http

# Host port publishing (docker compose)
JOSHGPT_MCP_PUBLISH_HOST=127.0.0.1
JOSHGPT_MCP_PUBLISH_PORT=8787

# Workspace mount (host path to expose read-only in container at /workspace)
JOSHGPT_MCP_WORKSPACE_HOST_PATH=.
# Docker socket mount for container exec tools
JOSHGPT_MCP_DOCKER_SOCKET_PATH=/var/run/docker.sock

# File access policy
JOSHGPT_MCP_ALLOWED_ROOTS=/workspace
JOSHGPT_MCP_DENY_SEGMENTS=.git,node_modules,__pycache__,.venv,.ssh,.codex

# Tool limits
JOSHGPT_MCP_MAX_FILE_BYTES=512000
JOSHGPT_MCP_MAX_LIST_ENTRIES=500
JOSHGPT_MCP_MAX_SEARCH_MATCHES=500

# Execution tools policy
# read-only | host | container | both
JOSHGPT_MCP_TOOLS_MODE=read-only

# Host command allowlist (basename tokens, comma-separated, '*' to allow all)
JOSHGPT_MCP_ALLOWED_HOST_COMMANDS=ls,cat,rg,grep,find,pwd,echo,git,gh,python,python3,sed,awk,head,tail,wc,stat,uname,date,id,whoami

# Container command policy
JOSHGPT_MCP_ALLOWED_CONTAINER_COMMANDS=ls,cat,rg,grep,find,pwd,echo,git,gh,python,python3,sed,awk,head,tail,wc,stat,uname,date,id,whoami
JOSHGPT_MCP_ALLOWED_CONTAINERS=
JOSHGPT_MCP_REQUIRE_CONTAINER_RUNNING=true

# Command execution bounds
JOSHGPT_MCP_DEFAULT_COMMAND_TIMEOUT_SECONDS=30
JOSHGPT_MCP_MAX_COMMAND_TIMEOUT_SECONDS=120
JOSHGPT_MCP_DEFAULT_COMMAND_OUTPUT_CHARS=12000
JOSHGPT_MCP_MAX_COMMAND_OUTPUT_CHARS=40000
JOSHGPT_MCP_MAX_COMMAND_ARGS=32
JOSHGPT_MCP_MAX_COMMAND_NAME_CHARS=128
JOSHGPT_MCP_MAX_ARG_CHARS=1024

# -----------------------------------------------------------------------------
# Dispatcher capability service
# -----------------------------------------------------------------------------
JOSHGPT_DISPATCHER_BIND_HOST=0.0.0.0
JOSHGPT_DISPATCHER_BIND_PORT=8788
JOSHGPT_DISPATCHER_TRANSPORT=streamable-http
JOSHGPT_DISPATCHER_PUBLISH_HOST=127.0.0.1
JOSHGPT_DISPATCHER_PUBLISH_PORT=8788
JOSHGPT_DISPATCHER_DB_PATH=/data/dispatcher.db
# Named volume by default (see compose)
JOSHGPT_DISPATCHER_DB_VOLUME=joshgpt-dispatcher-data
JOSHGPT_DISPATCHER_REQUIRE_SHARED_TOKEN=true
JOSHGPT_DISPATCHER_SHARED_TOKEN=replace-me-dispatcher-token

# -----------------------------------------------------------------------------
# Supervisor capability service (context-agnostic)
# -----------------------------------------------------------------------------
JOSHGPT_SUPERVISOR_BIND_HOST=0.0.0.0
JOSHGPT_SUPERVISOR_BIND_PORT=8789
JOSHGPT_SUPERVISOR_TRANSPORT=streamable-http
JOSHGPT_SUPERVISOR_PUBLISH_HOST=127.0.0.1
JOSHGPT_SUPERVISOR_PUBLISH_PORT=8789
JOSHGPT_SUPERVISOR_REQUIRE_SHARED_TOKEN=true
JOSHGPT_SUPERVISOR_SHARED_TOKEN=replace-me-supervisor-token
JOSHGPT_SUPERVISOR_DEFAULT_ESCALATE_ROLE=executive-sponsor
